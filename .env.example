# PostgreSQL (create database coaching_bot_pilot locally or on your host)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/coaching_bot_pilot?schema=public"

# App
PORT=3000

# Public base for file URLs returned by API (no trailing slash). Omit to return relative paths only.
FILES_PUBLIC_BASE_URL="http://localhost:3000"

# Gemini (embeddings: gemini-embedding-2-preview @ 768 dims)
GEMINI_API_KEY=""

# Chat / RAG (OpenAI — Gemini chat was replaced 2026-04-16; embeddings still use Gemini above)
OPENAI_CHAT_MODEL="gpt-4o-mini"
OPENAI_CHAT_TEMPERATURE="0.7"
OPENAI_CHAT_MAX_OUTPUT_TOKENS="2048"

# Legacy Gemini chat config — kept only as a fallback for GeminiChatService (not currently wired)
GEMINI_CHAT_MODEL="gemini-2.5-pro"
GEMINI_CHAT_TEMPERATURE="0.7"
GEMINI_CHAT_MAX_OUTPUT_TOKENS="2048"

RAG_TOP_K="8"
RAG_CONTEXT_MAX_CHARS="24000"

# Qdrant
QDRANT_HOST="localhost"
QDRANT_PORT="6333"
QDRANT_API_KEY=""
QDRANT_USE_TLS="false"
QDRANT_COLLECTION="coaching_bot_pilot_knowledge"
QDRANT_VECTOR_SIZE="768"

# Chunking defaults
CHUNK_SIZE="800"
CHUNK_OVERLAP="100"

JWT_SECRET="replace-with-min-64-random-characters-in-production"

OPENAI_API_KEY="sk-your-openai-key-here"
ELEVENLABS_API_KEY="your-elevenlabs-key-here"
ELEVENLABS_VOICE_ID_EN="dn9HtxgDwCH96MVX9iAO"
ELEVENLABS_VOICE_ID_DE="dn9HtxgDwCH96MVX9iAO"