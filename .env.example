# PostgreSQL (create database coaching_bot_pilot locally or on your host)
DATABASE_URL=""

# App
PORT=

# Public base for file URLs returned by API (no trailing slash). Omit to return relative paths only.
FILES_PUBLIC_BASE_URL=""

# Gemini (embeddings: gemini-embedding-2-preview @ 768 dims)
GEMINI_API_KEY=""

# Chat / RAG (Gemini Developer API — flash models are typical free-tier choices; override if needed)
GEMINI_CHAT_MODEL=""
GEMINI_CHAT_TEMPERATURE=""
GEMINI_CHAT_MAX_OUTPUT_TOKENS=""

RAG_TOP_K=""
RAG_CONTEXT_MAX_CHARS=""

# Qdrant
QDRANT_HOST=""
QDRANT_PORT=""
# gRPC (default 6334; shown in startup logs)
QDRANT_GRPC_PORT=""
QDRANT_API_KEY=""
QDRANT_USE_TLS=""
QDRANT_COLLECTION=""
QDRANT_VECTOR_SIZE=""

# Chunking defaults
CHUNK_SIZE=""
CHUNK_OVERLAP=""
