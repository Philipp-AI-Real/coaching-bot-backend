* text=auto

# Shell scripts must use LF — Windows CRLF breaks `#!/usr/bin/env bash`
# on the Linux deployment server.
*.sh         text eol=lf

# Dockerfile and compose run on Linux — keep LF.
Dockerfile   text eol=lf
*.yml        text eol=lf
*.yaml       text eol=lf

# Treat these as binary so they're never munged.
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.pdf binary
